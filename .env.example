# Frontend Environment Variables - Example
# Copy content to your .env or .env.production file

# Backend API URL
VITE_API_URL=https://your-backend-railway-url.railway.app/api
# or for Render:
# VITE_API_URL=https://your-backend-render-url.onrender.com/api

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Environment
VITE_NODE_ENV=production

# Optional: Analytics
VITE_ANALYTICS_ID=your_analytics_id

# Optional: Stripe Public Key (if using payments)
# VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# Optional: EmailJS Configuration
# VITE_EMAILJS_SERVICE_ID=service_xxxxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
# VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
